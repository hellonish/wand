{
  "manifest_version": 3,
  "name": "Hopper — Job Application Tracker",
  "version": "1.0.0",
  "description": "Automatically track job applications as you apply. Integrates with ineedajob.pro for AI-powered analysis.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "tabs"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "host_permissions": [
    "https://ineedajob.pro/*",
    "https://wandapi.ineedajob.pro/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://careers.icims.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://jobs.smartrecruiters.com/*",
    "https://*.bamboohr.com/*",
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://*.jobvite.com/*",
    "https://careers.google.com/*",
    "https://jobs.apple.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Hopper — Job Application Tracker"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://careers.icims.com/*",
        "https://*.taleo.net/*",
        "https://jobs.smartrecruiters.com/*",
        "https://*.bamboohr.com/*",
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://www.indeed.com/apply/*",
        "https://www.glassdoor.com/job-listing/*",
        "https://*.jobvite.com/careers/*",
        "https://careers.google.com/jobs/*",
        "https://jobs.apple.com/*"
      ],
      "js": ["config.js", "content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png",
        "icons/onboarding-hero.png",
        "onboarding/onboarding.html",
        "onboarding/onboarding.css",
        "onboarding/onboarding.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "settings/settings.html"
}
