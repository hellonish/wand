# ── LLM API Keys ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── URLs ───────────────────────────────────────────────────────────────────────
# Public URL of this backend (no trailing slash)
# Local:  http://localhost:8000
# Render: https://your-service.onrender.com
BACKEND_URL=http://localhost:8000

# Public URL of the frontend (no trailing slash)
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (default, omit for local dev):
# DATABASE_URL=sqlite:///./wand.db
# Supabase PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Test mode:  sk_test_...  (local dev)
# Live mode:  sk_live_...  (production on Render)
STRIPE_SECRET_KEY=

# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Price IDs — create separate ones in test AND live mode
# Test IDs: price_... from Stripe test mode
# Live IDs: price_... from Stripe live mode
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=
STRIPE_PRICE_TOPUP=
