# ── Google OAuth ───────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── URLs (no trailing slash) ───────────────────────────────────────────────────
# Public URL of this backend — used to build the Google OAuth redirect_uri
# Local:  http://localhost:8000
# Render: https://your-service.onrender.com
BACKEND_URL=http://localhost:8000

# Public URL of the frontend — users land here with ?token=... after login
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Security ───────────────────────────────────────────────────────────────────
# JWT signing + Starlette session cookie. Use a long random string in production.
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# Fernet key used to encrypt users' BYOK provider keys at rest.
# WARNING: never rotate once live — all stored keys become undecryptable.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# ── BYOK mode ──────────────────────────────────────────────────────────────────
# false → server falls back to the keys below when a user has no key of their own
# true  → every AI feature requires the user to add their own key (402 otherwise)
BYOK_REQUIRED=false

# ── Server-side LLM fallback (only used while BYOK_REQUIRED=false) ──────────────
# Default routing is grok, so XAI_API_KEY is the one that actually gets used.
# DEEPSEEK_API_KEY is only hit if api/llm_config.json routes a task to deepseek.
XAI_API_KEY=
DEEPSEEK_API_KEY=
# Optional model overrides (sensible defaults applied if omitted):
# XAI_MODEL=grok-3
# DEEPSEEK_MODEL=deepseek-chat

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (default — omit entirely for local dev):
# DATABASE_URL=sqlite:///./wand.db
# Supabase PostgreSQL (production — Supabase → Settings → Database → Connection string → URI):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Supabase Storage ────────────────────────────────────────────────────────────
# Supabase → Settings → API → Project URL
SUPABASE_URL=https://[PROJECT].supabase.co
# Supabase → Settings → API → service_role secret (NOT the anon key)
SUPABASE_SERVICE_KEY=
# Buckets to create in Supabase → Storage before first run:
#   avatars       → Public  (profile pictures)
#   wand-uploads  → Private (resume / linkedin / portfolio files)

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated. Defaults to * if omitted — always set this in production.
ALLOWED_ORIGINS=https://ineedajob.pro

# ── Google Custom Search — optional, powers reachout contact discovery ─────────
# Without these, reachout falls back to DuckDuckGo scraping.
# The API key needs the "Custom Search API" enabled in Google Cloud.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Debug (leave unset in production) ──────────────────────────────────────────
# LLM_DEBUG_CAPTURE=1                 # dump raw LLM request/response to disk
# LLM_DEBUG_LOG=llm_debug.jsonl       # where LLM_DEBUG_CAPTURE writes
# LLM_MAX_INPUT_CHARS=400000          # truncation budget for LLM inputs
# REACHOUT_SEARCH_PROVIDERS=ddgs,duckduckgo_html,google_cse  # search order override
